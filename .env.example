# ===========================================
# Frolf-Bot PWA Environment Configuration
# ===========================================

# NATS WebSocket URL
# Production: wss://nats.frolf-bot.com:443
# Local (with port forward): wss://localhost:4443
PUBLIC_NATS_URL=wss://nats.frolf-bot.com:443

# OpenTelemetry Collector base URL (browser client)
# Each signal exporter appends its own path: /v1/traces, /v1/metrics, /v1/logs
# Production: https://frolf-bot.duckdns.org
# Local (Alloy running locally): http://localhost:4318
PUBLIC_OTEL_ENDPOINT=http://localhost:4318

# OpenTelemetry Collector endpoint (server-side / Node.js only)
# In production this points to the internal K8s Alloy service.
# Production: http://alloy.observability.svc.cluster.local:4318
# Local: http://localhost:4318
PRIVATE_OTEL_ENDPOINT=http://localhost:4318

# API URL for Magic Link generation (not used by PWA directly)
PUBLIC_API_URL=https://api.frolf-bot.com

# Development Mode
# Set to 'true' to use mock data instead of live NATS
PUBLIC_USE_MOCK=false

# Debug Mode
# Set to 'true' to enable verbose console logging
PUBLIC_DEBUG=false

# Discord Activity — Client ID for the Discord Embedded App SDK
# Required for the /activity route. Get this from the Discord Developer Portal.
VITE_DISCORD_CLIENT_ID=
